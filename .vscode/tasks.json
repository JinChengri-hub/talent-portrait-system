{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "启动后端 (FastAPI)",
      "type": "shell",
      "command": "source venv/bin/activate && uvicorn app.main:app --reload --port 8000",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always",
        "group": "dev"
      },
      "problemMatcher": []
    },
    {
      "label": "启动前端 (Vue)",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always",
        "group": "dev"
      },
      "problemMatcher": []
    },
    {
      "label": "启动全部服务",
      "dependsOn": ["启动后端 (FastAPI)", "启动前端 (Vue)"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
